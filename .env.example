# ═══════════════════════════════════════════════════════════
# Environment variable overrides for config.yaml defaults.
# Variable names use "__" (double underscore) as nested delimiter,
# matching pydantic-settings env_nested_delimiter="__".
#
# Example:  DATABASE__TIMESCALE_URL  →  settings.database.timescale_url
# ═══════════════════════════════════════════════════════════

# ── Infrastructure ──────────────────────────────────────────
#
# ⚠️  Docker 部署时使用服务名（下方 "Docker" 一栏）；本地直接运行时使用 localhost。
#
# ── Local dev (直接运行) ────────────────────────────────────
# DATABASE__TIMESCALE_URL=postgresql+asyncpg://trader:trader_dev@localhost:5432/algo_trader
# DATABASE__POSTGRES_URL=postgresql+asyncpg://trader:trader_dev@localhost:5433/algo_trader_biz
# REDIS__URL=redis://localhost:6379/0
# REDIS__CLUSTER_ENABLED=false
# REDIS__CLUSTER_NODES=[{"host":"127.0.0.1","port":6380},{"host":"127.0.0.1","port":6381},{"host":"127.0.0.1","port":6382}]
# RABBITMQ__URL=amqp://trader:trader_dev@localhost:5672/
# MINIO__ENDPOINT=localhost:9000
# BROKER__FUTU__HOST=127.0.0.1
#
# ── Docker deploy (docker compose) ─────────────────────────
DATABASE__TIMESCALE_URL=postgresql+asyncpg://trader:trader_dev@timescaledb:5432/algo_trader
DATABASE__POSTGRES_URL=postgresql+asyncpg://trader:trader_dev@postgres:5432/algo_trader_biz

# Redis standalone（单节点模式）:
# REDIS__URL=redis://redis-node-1:6380/0

# Redis cluster（推荐生产模式）:
REDIS__CLUSTER_ENABLED=true
REDIS__CLUSTER_NODES=[{"host":"redis-node-1","port":6380},{"host":"redis-node-2","port":6381},{"host":"redis-node-3","port":6382}]

RABBITMQ__URL=amqp://trader:trader_dev@rabbitmq:5672/

MINIO__ENDPOINT=minio:9000
MINIO__ACCESS_KEY=minioadmin
MINIO__SECRET_KEY=minioadmin
# MINIO__SECURE=false

# ── Broker ──────────────────────────────────────────────────

BROKER__TYPE=paper                   # paper | futu
# BROKER__PAPER__INITIAL_CASH=100000.0
# BROKER__FUTU__HOST=127.0.0.1
# BROKER__FUTU__PORT=11111
# BROKER__FUTU__TRADER_ID=
# BROKER__FUTU__TRD_ENV=SIMULATE
# BROKER__FUTU__MARKET=US

# ── LLM ─────────────────────────────────────────────────────

LLM__OPENAI__API_KEY=sk-your-key-here
# LLM__OPENAI__MODEL=gpt-4o
LLM__COPILOT__GITHUB_TOKEN=
# LLM__COPILOT__CLI_PATH=copilot
# LLM__COPILOT__MODEL=gpt-4o
# LLM__COPILOT__REASONING_EFFORT=medium

# ── Trading ─────────────────────────────────────────────────

TRADING__TIMEZONE=America/New_York
# TRADING__EXECUTION_INTERVAL=300

# ── Celery Flower ───────────────────────────────────────────

FLOWER_USER=admin
FLOWER_PASSWORD=changeme
RABBITMQ_USER=trader
RABBITMQ_PASS=trader_dev

# ── Observability ───────────────────────────────────────────

LOGGING__LEVEL=INFO
# LOGGING__FORMAT=json
