# ═══════════════════════════════════════════════════════════
# Environment examples (pydantic nested delimiter: __)
# Match path in shared/config/settings.py, e.g.
# INFRA__DATABASE__TIMESCALE_URL -> settings.infra.database.timescale_url
# ═══════════════════════════════════════════════════════════

# ===========================================================
# Local dev examples (run services on host, not docker DNS)
# ===========================================================
# COMMON__TIMEZONE=America/New_York
# COMMON__LOGGING__LEVEL=INFO
# COMMON__LOGGING__FORMAT=json
#
# INFRA__DATABASE__TIMESCALE_URL=postgresql+asyncpg://trader:trader_dev@localhost:5432/algo_trader
# INFRA__DATABASE__POSTGRES_URL=postgresql+asyncpg://trader:trader_dev@localhost:5433/algo_trader_biz
# INFRA__REDIS__URL=redis://localhost:6379/0
# INFRA__RABBITMQ__URL=amqp://trader:trader_dev@localhost:5672//
#
# ANALYSIS_SERVICE__LLM__PROVIDER=copilot
# ANALYSIS_SERVICE__LLM__OPENAI__API_KEY=
# ANALYSIS_SERVICE__LLM__OPENAI__MODEL=claude-opus-4.6
# ANALYSIS_SERVICE__LLM__COPILOT__GITHUB_TOKEN=
# ANALYSIS_SERVICE__LLM__COPILOT__CLI_PATH=copilot
# ANALYSIS_SERVICE__LLM__COPILOT__MODEL=claude-opus-4.6
# ANALYSIS_SERVICE__LLM__COPILOT__REASONING_EFFORT=medium
# ANALYSIS_SERVICE__LLM__AGENTIC_MODE=true
#
# TRADE_SERVICE__EXECUTION_INTERVAL=300
# TRADE_SERVICE__BROKER__TYPE=paper
# TRADE_SERVICE__BROKER__PAPER__INITIAL_CASH=100000.0
# TRADE_SERVICE__BROKER__FUTU__HOST=127.0.0.1
# TRADE_SERVICE__BROKER__FUTU__PORT=11111
#
# MINIO__ENDPOINT=localhost:9000
# MINIO__ACCESS_KEY=minioadmin
# MINIO__SECRET_KEY=minioadmin
# MINIO__SECURE=false
#
# FLOWER_USER=admin
# FLOWER_PASSWORD=changeme
# RABBITMQ_USER=trader
# RABBITMQ_PASS=trader_dev

# ===========================================================
# Docker compose examples (service-name DNS)
# ===========================================================
INFRA__DATABASE__TIMESCALE_URL=postgresql+asyncpg://trader:trader_dev@algo_timescaledb:5432/algo_trader
INFRA__DATABASE__POSTGRES_URL=postgresql+asyncpg://trader:trader_dev@algo_postgres:5432/algo_trader_biz

INFRA__REDIS__URL=redis://algo_redis:6379/0

INFRA__RABBITMQ__URL=amqp://trader:trader_dev@algo_rabbitmq:5672//

COMMON__TIMEZONE=America/New_York
COMMON__LOGGING__LEVEL=INFO
COMMON__LOGGING__FORMAT=json

ANALYSIS_SERVICE__LLM__PROVIDER=copilot
ANALYSIS_SERVICE__LLM__OPENAI__API_KEY=sk-your-key-here
ANALYSIS_SERVICE__LLM__OPENAI__MODEL=claude-opus-4.6
ANALYSIS_SERVICE__LLM__COPILOT__GITHUB_TOKEN=
ANALYSIS_SERVICE__LLM__COPILOT__CLI_PATH=copilot
ANALYSIS_SERVICE__LLM__COPILOT__MODEL=claude-opus-4.6
ANALYSIS_SERVICE__LLM__COPILOT__REASONING_EFFORT=medium
ANALYSIS_SERVICE__LLM__AGENTIC_MODE=true

TRADE_SERVICE__EXECUTION_INTERVAL=300
TRADE_SERVICE__BROKER__TYPE=paper
TRADE_SERVICE__BROKER__PAPER__INITIAL_CASH=100000.0
# TRADE_SERVICE__BROKER__TYPE=futu
# TRADE_SERVICE__BROKER__FUTU__HOST=host.docker.internal
# TRADE_SERVICE__BROKER__FUTU__PORT=11111
# TRADE_SERVICE__BROKER__FUTU__TRADER_ID=
# TRADE_SERVICE__BROKER__FUTU__TRD_ENV=SIMULATE
# TRADE_SERVICE__BROKER__FUTU__MARKET=US

MINIO__ENDPOINT=algo_minio:9000
MINIO__ACCESS_KEY=minioadmin
MINIO__SECRET_KEY=minioadmin
MINIO__SECURE=false

FLOWER_USER=admin
FLOWER_PASSWORD=changeme
RABBITMQ_USER=trader
RABBITMQ_PASS=trader_dev

GRAFANA_PORT=3300
