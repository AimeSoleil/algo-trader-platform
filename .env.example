# ============================================================
# Database
# ============================================================
TIMESCALE_URL=postgresql+asyncpg://trader:trader_dev@localhost:5432/algo_trader
POSTGRES_URL=postgresql+asyncpg://trader:trader_dev@localhost:5433/algo_trader_biz

# ============================================================
# Redis
# ============================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================
# RabbitMQ
# ============================================================
RABBITMQ_URL=amqp://trader:trader_dev@localhost:5672/

# ============================================================
# MinIO
# ============================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ============================================================
# LLM
# ============================================================
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
COPILOT_CLI_PATH=copilot
COPILOT_GITHUB_TOKEN=
# SKILL_DIR=                        # leave empty for default; providers auto-resolve

# ============================================================
# Trading
# ============================================================
DEFAULT_STRATEGY_TYPE=option
TIMEZONE=America/New_York

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO
