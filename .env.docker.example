# ═══════════════════════════════════════════════════════════
# .env.docker.example — Docker Compose deployment
# ═══════════════════════════════════════════════════════════
# Copy to .env before running docker compose.
# Uses Docker DNS hostnames (algo_timescaledb, algo_redis, etc.)
# Most values match config.yaml defaults unless noted below.
# LLM defaults below track the latest DeepSeek-first config.
# ═══════════════════════════════════════════════════════════


# ── Common ──────────────────────────────────────────────────
COMMON__TIMEZONE=America/New_York

# Watchlist — JSON arrays (override config.yaml lists)
# Keep COMMON__WATCHLIST__FOR_TRADE_BENCHMARK as a subset of COMMON__WATCHLIST__FOR_DATA_SIGNAL.
# NOTE: single-quote the value so bash source preserves inner double-quotes.
COMMON__WATCHLIST__FOR_DATA_SIGNAL='["SPY","QQQ","IWM","DIA","TLT","VXX","AAPL","MSFT","TSLA","AMZN","META","GOOGL","AMD","TSM","NVDA","AVGO","SMCI","MU","ANET","AMAT","ORCL","WOLF","PLTR","CRM","FISV","V","JPM","UNH","LLY","UPS","FDX","WMT","T","LITE","MRVL","CIEN","AAOI","OKLO","BWXT","CCJ","GEV","ON","MPWR","RKLB","ASTS","PL","IONQ","RGTI","CRWV","DOCN","PANW","CRWD","ZS","COIN","IBIT"]'
COMMON__WATCHLIST__FOR_TRADE_BENCHMARK='["SPY","QQQ","IWM","DIA"]'
COMMON__WATCHLIST__FOR_SIGNAL_BENCHMARK='["SPY","QQQ","IWM","TLT","^VIX","GLD","HYG","XLE","IBIT"]'

# Logging
COMMON__LOGGING__LEVEL=DEBUG
COMMON__LOGGING__LIB_LEVEL=INFO
COMMON__LOGGING__FORMAT=json

# Celery runtime
COMMON__CELERY__PREFETCH_MULTIPLIER=4
COMMON__CELERY__MAX_MEMORY_PER_CHILD=300000
COMMON__CELERY__TASK_ACKS_LATE=true
COMMON__CELERY__TASK_TRACK_STARTED=true
COMMON__CELERY__TASK_SOFT_TIME_LIMIT=600
COMMON__CELERY__TASK_TIME_LIMIT=900
COMMON__CELERY__TASK_REJECT_ON_WORKER_LOST=true
COMMON__CELERY__CONCURRENCY=0

# Beat
COMMON__BEAT__REDBEAT_LOCK_TIMEOUT=1800

# Flower
COMMON__FLOWER__PORT=5555
COMMON__FLOWER__BASIC_AUTH_USER=admin
COMMON__FLOWER__BASIC_AUTH_PASSWORD=changeme

# Notifier
COMMON__NOTIFIER__ENABLED=true
COMMON__NOTIFIER__DAILY_REPORT_TIME=16:30
COMMON__NOTIFIER__BACKENDS__0__TYPE=discord
COMMON__NOTIFIER__BACKENDS__0__ENABLED=true
COMMON__NOTIFIER__BACKENDS__0__WEBHOOK_URL=
COMMON__NOTIFIER__BACKENDS__0__TIMEOUT=10.0


# ── Infrastructure (Docker DNS) ─────────────────────────────
# These INFRA__ vars are the single source used by both:
# 1) application settings (Pydantic)
# 2) docker-compose bootstrap for DB/Redis containers
INFRA__DATABASE__TIMESCALE_USER=trader
INFRA__DATABASE__TIMESCALE_PASSWORD=trader_dev
INFRA__DATABASE__TIMESCALE_HOST=algo_timescaledb
INFRA__DATABASE__TIMESCALE_PORT=5432
INFRA__DATABASE__TIMESCALE_DB=algo_trader
INFRA__DATABASE__POSTGRES_USER=trader
INFRA__DATABASE__POSTGRES_PASSWORD=trader_dev
INFRA__DATABASE__POSTGRES_HOST=algo_postgres
INFRA__DATABASE__POSTGRES_PORT=5432
INFRA__DATABASE__POSTGRES_DB=algo_trader_biz
INFRA__REDIS__PASSWORD=redis_trader_dev_secure
INFRA__REDIS__HOST=algo_redis
INFRA__REDIS__PORT=6379
INFRA__REDIS__DB=0
INFRA__RABBITMQ__USER=trader
INFRA__RABBITMQ__PASSWORD=trader_dev
INFRA__RABBITMQ__HOST=algo_rabbitmq
INFRA__RABBITMQ__PORT=5672
INFRA__RABBITMQ__VHOST=/
INFRA__PROMETHEUS__URL=http://algo_prometheus:9090
INFRA__GRAFANA__URL=http://algo_grafana:3300


# ── Data Service ────────────────────────────────────────────
# DATA_SERVICE__PROVIDERS__STOCK=yfinance
# DATA_SERVICE__PROVIDERS__OPTIONS=yfinance
# DATA_SERVICE__RESILIENCE__MAX_RETRIES=1
# DATA_SERVICE__RESILIENCE__CONCURRENT_SYMBOLS=3
DATA_SERVICE__WORKER__SCHEDULE__OPTIONS_CAPTURE_EVERY_MINUTES=5
DATA_SERVICE__WORKER__SCHEDULE__POST_MARKET_TIME=17:00
DATA_SERVICE__WORKER__SCHEDULE__REFRESH_EARNINGS_TIME=16:50
DATA_SERVICE__WORKER__PIPELINE__CHUNK_SIZE=5
DATA_SERVICE__WORKER__PIPELINE__STOP_AFTER=compute_daily_signals
DATA_SERVICE__WORKER__PIPELINE__COORDINATION_TIMEOUT_MINUTES=60


# ── Signal Service ──────────────────────────────────────────
# SIGNAL_SERVICE__IV_LOOKBACK_DAYS=252


# ── Analysis Service — LLM ──────────────────────────────────
# Template default: provider=deepseek, model=deepseek-v4-pro
ANALYSIS_SERVICE__DAILY_TASK_CHUNK_SIZE=20
ANALYSIS_SERVICE__LLM__PROVIDER=deepseek
ANALYSIS_SERVICE__LLM__OPENAI__API_KEY=sk-your-key-here
ANALYSIS_SERVICE__LLM__OPENAI__MODEL=claude-opus-4.6
ANALYSIS_SERVICE__LLM__CLOSEAI__API_KEY=your-closeai-api-key-here
ANALYSIS_SERVICE__LLM__CLOSEAI__BASE_URL=https://api.openai-proxy.org/v1
ANALYSIS_SERVICE__LLM__CLOSEAI__MODEL=claude-sonnet-4-20250514
ANALYSIS_SERVICE__LLM__CLOSEAI__REASONING_EFFORT=high
ANALYSIS_SERVICE__LLM__CLOSEAI__TEMPERATURE=0.1
ANALYSIS_SERVICE__LLM__CLOSEAI__MAX_TOKENS=32768
ANALYSIS_SERVICE__LLM__DEEPSEEK__API_KEY=your-deepseek-api-key-here
ANALYSIS_SERVICE__LLM__DEEPSEEK__BASE_URL=https://api.deepseek.com
ANALYSIS_SERVICE__LLM__DEEPSEEK__MODEL=deepseek-v4-pro
ANALYSIS_SERVICE__LLM__DEEPSEEK__REASONING_EFFORT=high
ANALYSIS_SERVICE__LLM__DEEPSEEK__TEMPERATURE=0.1
ANALYSIS_SERVICE__LLM__DEEPSEEK__MAX_TOKENS=32768
# Per-agent model overrides (empty = use provider default above)
# ANALYSIS_SERVICE__LLM__AGENT_MODELS_OVERRIDE__TREND=
# ANALYSIS_SERVICE__LLM__AGENT_MODELS_OVERRIDE__VOLATILITY=
# ANALYSIS_SERVICE__LLM__AGENT_MODELS_OVERRIDE__FLOW=
# ANALYSIS_SERVICE__LLM__AGENT_MODELS_OVERRIDE__CHAIN=
# ANALYSIS_SERVICE__LLM__AGENT_MODELS_OVERRIDE__SPREAD=
# ANALYSIS_SERVICE__LLM__AGENT_MODELS_OVERRIDE__CROSS_ASSET=
# ANALYSIS_SERVICE__LLM__AGENT_MODELS_OVERRIDE__SYNTHESIZER=
# ANALYSIS_SERVICE__LLM__AGENT_MODELS_OVERRIDE__CRITIC=
# ANALYSIS_SERVICE__LLM__ORCHESTRATOR_CHUNK_SIZE=5
# ANALYSIS_SERVICE__LLM__ORCHESTRATOR_MAX_PARALLEL=2
# ANALYSIS_SERVICE__LLM__MAX_CRITIC_REVISIONS=0
# ANALYSIS_SERVICE__LLM__SPECIALIST_PARALLEL_LIMIT=2
# ANALYSIS_SERVICE__LLM__MAX_RETRIES=0


# ── Trade Service ───────────────────────────────────────────
TRADE_SERVICE__EXECUTION_INTERVAL=300
TRADE_SERVICE__TRADE_START_TIME=09:25
TRADE_SERVICE__BROKER__TYPE=paper
TRADE_SERVICE__BROKER__PAPER__INITIAL_CASH=100000.0
# TRADE_SERVICE__BROKER__FUTU__HOST=host.docker.internal
# TRADE_SERVICE__BROKER__FUTU__PORT=11111
# TRADE_SERVICE__BROKER__FUTU__TRADER_ID=
# TRADE_SERVICE__BROKER__FUTU__TRD_ENV=SIMULATE
# TRADE_SERVICE__BROKER__FUTU__MARKET=US
TRADE_SERVICE__RISK__STOP_LOSS__ENABLED=true
TRADE_SERVICE__RISK__STOP_LOSS__PORTFOLIO_LOSS_LIMIT=2000.0
TRADE_SERVICE__RISK__STOP_LOSS__POSITION_LOSS_LIMIT=500.0


# ── Docker Compose helpers (not Pydantic — used in compose YAML) ──
FLOWER_USER=admin
FLOWER_PASSWORD=changeme
GRAFANA_PORT=3300
