# ═══════════════════════════════════════════════════════════
# Docker Compose 部署环境变量
# ⚠️  生产环境请修改所有密码和 API Key
# ═══════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────
DATABASE__TIMESCALE_URL=postgresql+asyncpg://trader:trader_dev@timescaledb:5432/algo_trader
DATABASE__POSTGRES_URL=postgresql+asyncpg://trader:trader_dev@postgres:5432/algo_trader_biz

# ── Redis Cluster ─────────────────────────────────────────────
REDIS__CLUSTER_ENABLED=true
REDIS__CLUSTER_NODES=[{"host":"redis-node-1","port":6380},{"host":"redis-node-2","port":6381},{"host":"redis-node-3","port":6382}]

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ__URL=amqp://trader:trader_dev@rabbitmq:5672//
RABBITMQ_USER=trader
RABBITMQ_PASS=trader_dev

# ── MinIO ─────────────────────────────────────────────────────
MINIO__ENDPOINT=minio:9000
MINIO__ACCESS_KEY=minioadmin
MINIO__SECRET_KEY=minioadmin
MINIO__SECURE=false

# ── Broker ────────────────────────────────────────────────────
BROKER__TYPE=paper
BROKER__PAPER__INITIAL_CASH=100000.0
# 若使用 Futu，取消注释并填写：
# BROKER__TYPE=futu
# BROKER__FUTU__HOST=host.docker.internal
# BROKER__FUTU__PORT=11111
# BROKER__FUTU__TRADER_ID=
# BROKER__FUTU__TRD_ENV=SIMULATE
# BROKER__FUTU__MARKET=US

# ── LLM ───────────────────────────────────────────────────────
LLM__OPENAI__API_KEY=sk-your-key-here
LLM__OPENAI__MODEL=gpt-4o
LLM__COPILOT__GITHUB_TOKEN=
# LLM__COPILOT__CLI_PATH=copilot
# LLM__COPILOT__MODEL=gpt-4o
# LLM__COPILOT__REASONING_EFFORT=medium

# ── Celery Flower ─────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=changeme

# ── Observability ─────────────────────────────────────────────
GRAFANA_PORT=3300
LOGGING__LEVEL=INFO
