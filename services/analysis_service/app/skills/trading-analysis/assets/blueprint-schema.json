{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LLMTradingBlueprint",
  "description": "Next-day options trading blueprint generated by the trading-analysis skill",
  "type": "object",
  "required": ["market_regime", "market_analysis", "symbol_plans", "max_total_positions", "max_daily_loss", "max_margin_usage", "portfolio_delta_limit", "portfolio_gamma_limit"],
  "properties": {
    "market_regime": {
      "type": "string",
      "enum": ["high_vol", "low_vol", "trending_up", "trending_down", "ranging", "neutral"]
    },
    "market_analysis": {
      "type": "string",
      "description": "Brief market assessment"
    },
    "symbol_plans": {
      "type": "array",
      "items": { "$ref": "#/$defs/SymbolPlan" }
    },
    "max_total_positions": { "type": "integer" },
    "max_daily_loss": { "type": "number" },
    "max_margin_usage": { "type": "number", "minimum": 0, "maximum": 1 },
    "portfolio_delta_limit": { "type": "number" },
    "portfolio_gamma_limit": { "type": "number" }
  },
  "$defs": {
    "SymbolPlan": {
      "type": "object",
      "required": ["underlying", "strategy_type", "direction", "legs", "entry_conditions", "exit_conditions", "max_position_size", "stop_loss_amount", "max_loss_per_trade", "reasoning", "confidence"],
      "properties": {
        "underlying": { "type": "string" },
        "strategy_type": {
          "type": "string",
          "enum": ["single_leg", "vertical_spread", "iron_condor", "iron_butterfly", "butterfly", "calendar_spread", "diagonal_spread", "straddle", "strangle", "covered_call", "protective_put", "collar"]
        },
        "direction": { "type": "string", "enum": ["bullish", "bearish", "neutral"] },
        "legs": {
          "type": "array",
          "items": { "$ref": "#/$defs/OptionLeg" }
        },
        "entry_conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/TriggerCondition" }
        },
        "exit_conditions": {
          "type": "array",
          "items": { "$ref": "#/$defs/TriggerCondition" },
          "description": "MUST include at least one stop-loss condition"
        },
        "adjustment_rules": {
          "type": "array",
          "items": { "$ref": "#/$defs/AdjustmentRule" }
        },
        "max_position_size": { "type": "integer" },
        "stop_loss_amount": { "type": "number" },
        "take_profit_amount": { "type": "number" },
        "max_loss_per_trade": { "type": "number" },
        "reasoning": { "type": "string", "description": "Must reference indicators and reference analyses that drove the decision" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "OptionLeg": {
      "type": "object",
      "required": ["expiry", "strike", "option_type", "side", "quantity"],
      "properties": {
        "expiry": { "type": "string", "format": "date" },
        "strike": { "type": "number" },
        "option_type": { "type": "string", "enum": ["call", "put"] },
        "side": { "type": "string", "enum": ["buy", "sell"] },
        "quantity": { "type": "integer" }
      }
    },
    "TriggerCondition": {
      "type": "object",
      "required": ["field", "operator", "value"],
      "properties": {
        "field": {
          "type": "string",
          "enum": ["underlying_price", "iv", "iv_rank", "delta", "gamma", "theta", "portfolio_delta", "spread_width", "time", "pnl_percent", "volume"]
        },
        "operator": {
          "type": "string",
          "enum": [">", ">=", "<", "<=", "==", "between", "crosses_above", "crosses_below"]
        },
        "value": {
          "oneOf": [
            { "type": "number" },
            { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 }
          ]
        }
      }
    },
    "AdjustmentRule": {
      "type": "object",
      "properties": {
        "trigger": { "$ref": "#/$defs/TriggerCondition" },
        "action": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  }
}
