{
  "$defs": {
    "AdjustmentAction": {
      "enum": [
        "hedge_delta",
        "roll_strike",
        "close_leg",
        "add_leg",
        "close_all"
      ],
      "title": "AdjustmentAction",
      "type": "string"
    },
    "AdjustmentRule": {
      "description": "\u76d8\u4e2d\u52a8\u6001\u8c03\u6574\u89c4\u5219",
      "properties": {
        "trigger": {
          "$ref": "#/$defs/TriggerCondition"
        },
        "action": {
          "$ref": "#/$defs/AdjustmentAction"
        },
        "params": {
          "additionalProperties": true,
          "title": "Params",
          "type": "object"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "trigger",
        "action"
      ],
      "title": "AdjustmentRule",
      "type": "object"
    },
    "BlueprintStatus": {
      "enum": [
        "pending",
        "active",
        "completed",
        "cancelled"
      ],
      "title": "BlueprintStatus",
      "type": "string"
    },
    "ConditionField": {
      "description": "\u89c4\u5219\u5f15\u64ce\u53ef\u8bfb\u53d6\u7684\u5b57\u6bb5",
      "enum": [
        "underlying_price",
        "iv",
        "iv_rank",
        "delta",
        "gamma",
        "theta",
        "portfolio_delta",
        "spread_width",
        "time",
        "pnl_percent",
        "volume"
      ],
      "title": "ConditionField",
      "type": "string"
    },
    "ConditionOperator": {
      "enum": [
        ">",
        ">=",
        "<",
        "<=",
        "==",
        "between",
        "crosses_above",
        "crosses_below"
      ],
      "title": "ConditionOperator",
      "type": "string"
    },
    "Direction": {
      "enum": [
        "bullish",
        "bearish",
        "neutral"
      ],
      "title": "Direction",
      "type": "string"
    },
    "OptionLeg": {
      "description": "\u671f\u6743\u7b56\u7565\u5355\u817f",
      "properties": {
        "expiry": {
          "format": "date",
          "title": "Expiry",
          "type": "string"
        },
        "strike": {
          "title": "Strike",
          "type": "number"
        },
        "option_type": {
          "title": "Option Type",
          "type": "string"
        },
        "side": {
          "title": "Side",
          "type": "string"
        },
        "quantity": {
          "default": 1,
          "title": "Quantity",
          "type": "integer"
        }
      },
      "required": [
        "expiry",
        "strike",
        "option_type",
        "side"
      ],
      "title": "OptionLeg",
      "type": "object"
    },
    "StrategyType": {
      "description": "\u652f\u6301\u7684\u671f\u6743\u7b56\u7565\u7c7b\u578b",
      "enum": [
        "single_leg",
        "vertical_spread",
        "iron_condor",
        "iron_butterfly",
        "butterfly",
        "calendar_spread",
        "diagonal_spread",
        "straddle",
        "strangle",
        "covered_call",
        "protective_put",
        "collar"
      ],
      "title": "StrategyType",
      "type": "string"
    },
    "SymbolPlan": {
      "description": "\u5355\u4e2a\u6807\u7684\u7684\u4ea4\u6613\u8ba1\u5212",
      "properties": {
        "underlying": {
          "title": "Underlying",
          "type": "string"
        },
        "strategy_type": {
          "$ref": "#/$defs/StrategyType"
        },
        "direction": {
          "$ref": "#/$defs/Direction"
        },
        "legs": {
          "items": {
            "$ref": "#/$defs/OptionLeg"
          },
          "minItems": 1,
          "title": "Legs",
          "type": "array"
        },
        "entry_conditions": {
          "items": {
            "$ref": "#/$defs/TriggerCondition"
          },
          "title": "Entry Conditions",
          "type": "array"
        },
        "exit_conditions": {
          "items": {
            "$ref": "#/$defs/TriggerCondition"
          },
          "title": "Exit Conditions",
          "type": "array"
        },
        "adjustment_rules": {
          "items": {
            "$ref": "#/$defs/AdjustmentRule"
          },
          "title": "Adjustment Rules",
          "type": "array"
        },
        "max_position_size": {
          "default": 1,
          "title": "Max Position Size",
          "type": "integer"
        },
        "stop_loss_amount": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stop Loss Amount"
        },
        "take_profit_amount": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Take Profit Amount"
        },
        "max_loss_per_trade": {
          "default": 500.0,
          "title": "Max Loss Per Trade",
          "type": "number"
        },
        "reasoning": {
          "default": "",
          "title": "Reasoning",
          "type": "string"
        },
        "confidence": {
          "default": 0.5,
          "title": "Confidence",
          "type": "number"
        }
      },
      "required": [
        "underlying",
        "strategy_type",
        "direction"
      ],
      "title": "SymbolPlan",
      "type": "object"
    },
    "TriggerCondition": {
      "description": "\u89c4\u5219\u5f15\u64ce\u53ef\u673a\u68b0\u5224\u5b9a\u7684\u89e6\u53d1\u6761\u4ef6",
      "properties": {
        "field": {
          "$ref": "#/$defs/ConditionField"
        },
        "operator": {
          "$ref": "#/$defs/ConditionOperator"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            }
          ],
          "description": "\u9608\u503c\uff1bBETWEEN \u65f6\u4e3a [low, high] \u5217\u8868",
          "title": "Value"
        },
        "timeframe": {
          "default": "realtime",
          "title": "Timeframe",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "field",
        "operator",
        "value"
      ],
      "title": "TriggerCondition",
      "type": "object"
    }
  },
  "description": "Next-day options trading blueprint generated by the trading-analysis skill",
  "properties": {
    "market_regime": {
      "default": "neutral",
      "title": "Market Regime",
      "type": "string"
    },
    "market_analysis": {
      "default": "",
      "title": "Market Analysis",
      "type": "string"
    },
    "symbol_plans": {
      "items": {
        "$ref": "#/$defs/SymbolPlan"
      },
      "title": "Symbol Plans",
      "type": "array"
    },
    "max_total_positions": {
      "default": 10,
      "title": "Max Total Positions",
      "type": "integer"
    },
    "max_daily_loss": {
      "default": 2000.0,
      "title": "Max Daily Loss",
      "type": "number"
    },
    "max_margin_usage": {
      "default": 0.5,
      "title": "Max Margin Usage",
      "type": "number"
    },
    "portfolio_delta_limit": {
      "default": 0.5,
      "title": "Portfolio Delta Limit",
      "type": "number"
    },
    "portfolio_gamma_limit": {
      "default": 0.1,
      "title": "Portfolio Gamma Limit",
      "type": "number"
    }
  },
  "required": [],
  "title": "LLMTradingBlueprint",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
