{
  "$defs": {
    "AdjustmentAction": {
      "enum": [
        "hedge_delta",
        "roll_strike",
        "close_leg",
        "add_leg",
        "close_all"
      ],
      "title": "AdjustmentAction",
      "type": "string"
    },
    "AdjustmentRule": {
      "description": "\u76d8\u4e2d\u52a8\u6001\u8c03\u6574\u89c4\u5219",
      "properties": {
        "trigger": {
          "$ref": "#/$defs/TriggerCondition"
        },
        "action": {
          "$ref": "#/$defs/AdjustmentAction"
        },
        "params": {
          "additionalProperties": true,
          "title": "Params",
          "type": "object"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "trigger",
        "action"
      ],
      "title": "AdjustmentRule",
      "type": "object"
    },
    "BlueprintStatus": {
      "enum": [
        "pending",
        "active",
        "completed",
        "cancelled"
      ],
      "title": "BlueprintStatus",
      "type": "string"
    },
    "ConditionField": {
      "description": "\u89c4\u5219\u5f15\u64ce\u53ef\u8bfb\u53d6\u7684\u5b57\u6bb5",
      "enum": [
        "underlying_price",
        "iv",
        "iv_rank",
        "delta",
        "gamma",
        "theta",
        "portfolio_delta",
        "spread_width",
        "time",
        "pnl_percent",
        "volume"
      ],
      "title": "ConditionField",
      "type": "string"
    },
    "ConditionOperator": {
      "enum": [
        ">",
        ">=",
        "<",
        "<=",
        "==",
        "between",
        "crosses_above",
        "crosses_below"
      ],
      "title": "ConditionOperator",
      "type": "string"
    },
    "DataQuality": {
      "description": "\u6570\u636e\u8d28\u91cf\u6807\u6ce8 \u2014 \u6807\u8bb0\u4fe1\u53f7\u8ba1\u7b97\u6240\u4f9d\u8d56\u7684\u6570\u636e\u662f\u5426\u5145\u8db3\u3002\n\ncomplete=True \u8868\u793a\u6240\u6709\u6307\u6807\u5747\u57fa\u4e8e\u5b8c\u6574\u6570\u636e\u8ba1\u7b97\uff1b\ncomplete=False \u8868\u793a\u90e8\u5206\u6307\u6807\u53ef\u80fd\u964d\u7ea7\u6216\u4f7f\u7528\u9ed8\u8ba4\u503c\u3002",
      "properties": {
        "complete": {
          "default": true,
          "title": "Complete",
          "type": "boolean"
        },
        "score": {
          "default": 1.0,
          "description": "\u7efc\u5408\u8d28\u91cf\u8bc4\u5206 0-1",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Score",
          "type": "number"
        },
        "warnings": {
          "description": "\u8d28\u91cf\u95ee\u9898\u63cf\u8ff0",
          "items": {
            "type": "string"
          },
          "title": "Warnings",
          "type": "array"
        },
        "stock_bar_count": {
          "default": 0,
          "description": "\u80a1\u7968 OHLCV \u884c\u6570",
          "title": "Stock Bar Count",
          "type": "integer"
        },
        "option_row_count": {
          "default": 0,
          "description": "\u671f\u6743\u94fe\u884c\u6570",
          "title": "Option Row Count",
          "type": "integer"
        },
        "degraded_indicators": {
          "description": "\u56e0\u6570\u636e\u4e0d\u8db3\u800c\u964d\u7ea7/\u4f7f\u7528\u9ed8\u8ba4\u503c\u7684\u6307\u6807\u540d",
          "items": {
            "type": "string"
          },
          "title": "Degraded Indicators",
          "type": "array"
        }
      },
      "title": "DataQuality",
      "type": "object"
    },
    "Direction": {
      "enum": [
        "bullish",
        "bearish",
        "neutral"
      ],
      "title": "Direction",
      "type": "string"
    },
    "OptionLeg": {
      "description": "\u671f\u6743\u7b56\u7565\u5355\u817f",
      "properties": {
        "expiry": {
          "format": "date",
          "title": "Expiry",
          "type": "string"
        },
        "strike": {
          "title": "Strike",
          "type": "number"
        },
        "option_type": {
          "enum": [
            "call",
            "put"
          ],
          "title": "Option Type",
          "type": "string"
        },
        "side": {
          "enum": [
            "buy",
            "sell"
          ],
          "title": "Side",
          "type": "string"
        },
        "quantity": {
          "default": 1,
          "title": "Quantity",
          "type": "integer"
        }
      },
      "required": [
        "expiry",
        "strike",
        "option_type",
        "side"
      ],
      "title": "OptionLeg",
      "type": "object"
    },
    "StrategyType": {
      "description": "\u652f\u6301\u7684\u671f\u6743\u7b56\u7565\u7c7b\u578b",
      "enum": [
        "single_leg",
        "vertical_spread",
        "iron_condor",
        "iron_butterfly",
        "butterfly",
        "calendar_spread",
        "diagonal_spread",
        "straddle",
        "strangle",
        "covered_call",
        "protective_put",
        "collar"
      ],
      "title": "StrategyType",
      "type": "string"
    },
    "SymbolPlan": {
      "description": "\u5355\u4e2a\u6807\u7684\u7684\u4ea4\u6613\u8ba1\u5212",
      "properties": {
        "underlying": {
          "title": "Underlying",
          "type": "string"
        },
        "strategy_type": {
          "$ref": "#/$defs/StrategyType"
        },
        "direction": {
          "$ref": "#/$defs/Direction"
        },
        "legs": {
          "items": {
            "$ref": "#/$defs/OptionLeg"
          },
          "minItems": 1,
          "title": "Legs",
          "type": "array"
        },
        "entry_conditions": {
          "items": {
            "$ref": "#/$defs/TriggerCondition"
          },
          "title": "Entry Conditions",
          "type": "array"
        },
        "exit_conditions": {
          "items": {
            "$ref": "#/$defs/TriggerCondition"
          },
          "title": "Exit Conditions",
          "type": "array"
        },
        "adjustment_rules": {
          "items": {
            "$ref": "#/$defs/AdjustmentRule"
          },
          "title": "Adjustment Rules",
          "type": "array"
        },
        "max_position_size": {
          "default": 1.0,
          "description": "\u4ed3\u4f4d\u6bd4\u4f8b (1.0=\u5168\u4ed3, 0.5=\u534a\u4ed3)",
          "maximum": 1.5,
          "minimum": 0.0,
          "title": "Max Position Size",
          "type": "number"
        },
        "max_contracts": {
          "default": 1,
          "description": "\u6700\u5927\u5408\u7ea6\u7ec4\u6570",
          "minimum": 1,
          "title": "Max Contracts",
          "type": "integer"
        },
        "stop_loss_amount": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stop Loss Amount"
        },
        "take_profit_amount": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Take Profit Amount"
        },
        "max_loss_per_trade": {
          "default": 500.0,
          "description": "\u5355\u7b14\u6700\u5927\u4e8f\u635f",
          "exclusiveMinimum": 0,
          "title": "Max Loss Per Trade",
          "type": "number"
        },
        "reasoning": {
          "default": "",
          "title": "Reasoning",
          "type": "string"
        },
        "confidence": {
          "default": 0.5,
          "description": "\u7f6e\u4fe1\u5ea6 0-1",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "data_quality_score": {
          "default": 1.0,
          "description": "\u4fe1\u53f7\u6570\u636e\u7efc\u5408\u8d28\u91cf 0-1",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Data Quality Score",
          "type": "number"
        },
        "data_quality_warnings": {
          "description": "\u6570\u636e\u8d28\u91cf\u95ee\u9898\u63cf\u8ff0",
          "items": {
            "type": "string"
          },
          "title": "Data Quality Warnings",
          "type": "array"
        },
        "signal_data_quality": {
          "anyOf": [
            {
              "$ref": "#/$defs/DataQuality"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "\u5b8c\u6574\u4fe1\u53f7\u6570\u636e\u8d28\u91cf\u5bf9\u8c61"
        }
      },
      "required": [
        "underlying",
        "strategy_type",
        "direction"
      ],
      "title": "SymbolPlan",
      "type": "object"
    },
    "TriggerCondition": {
      "description": "\u89c4\u5219\u5f15\u64ce\u53ef\u673a\u68b0\u5224\u5b9a\u7684\u89e6\u53d1\u6761\u4ef6",
      "properties": {
        "field": {
          "$ref": "#/$defs/ConditionField"
        },
        "operator": {
          "$ref": "#/$defs/ConditionOperator"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            }
          ],
          "description": "\u9608\u503c\uff1bBETWEEN \u65f6\u4e3a [low, high] \u5217\u8868",
          "title": "Value"
        },
        "timeframe": {
          "default": "realtime",
          "title": "Timeframe",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        }
      },
      "required": [
        "field",
        "operator",
        "value"
      ],
      "title": "TriggerCondition",
      "type": "object"
    }
  },
  "description": "Next-day options trading blueprint generated by the trading-analysis skill",
  "properties": {
    "market_regime": {
      "default": "neutral",
      "title": "Market Regime",
      "type": "string"
    },
    "market_analysis": {
      "default": "",
      "title": "Market Analysis",
      "type": "string"
    },
    "symbol_plans": {
      "items": {
        "$ref": "#/$defs/SymbolPlan"
      },
      "title": "Symbol Plans",
      "type": "array"
    },
    "max_total_positions": {
      "default": 10,
      "title": "Max Total Positions",
      "type": "integer"
    },
    "max_daily_loss": {
      "default": 2000.0,
      "title": "Max Daily Loss",
      "type": "number"
    },
    "max_margin_usage": {
      "default": 0.5,
      "title": "Max Margin Usage",
      "type": "number"
    },
    "portfolio_delta_limit": {
      "default": 0.5,
      "title": "Portfolio Delta Limit",
      "type": "number"
    },
    "portfolio_gamma_limit": {
      "default": 0.1,
      "title": "Portfolio Gamma Limit",
      "type": "number"
    },
    "min_data_quality_score": {
      "default": 1.0,
      "description": "\u6240\u6709\u6807\u7684\u4e2d\u6700\u4f4e\u6570\u636e\u8d28\u91cf\u5206",
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Min Data Quality Score",
      "type": "number"
    },
    "data_quality_summary": {
      "description": "\u5168\u5c40\u6570\u636e\u8d28\u91cf\u8b66\u544a",
      "items": {
        "type": "string"
      },
      "title": "Data Quality Summary",
      "type": "array"
    },
    "missing_symbols": {
      "description": "Symbols lost due to chunk failures",
      "items": {
        "type": "string"
      },
      "title": "Missing Symbols",
      "type": "array"
    },
    "reasoning_context": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Full LLM reasoning chain for auditability",
      "title": "Reasoning Context"
    }
  },
  "required": [],
  "title": "LLMTradingBlueprint",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
