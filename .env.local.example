# ═══════════════════════════════════════════════════════════
# .env.example — Local development (services on host)
# ═══════════════════════════════════════════════════════════
# Pydantic nested delimiter: __ (double underscore)
# Maps to shared/config/settings.py, e.g.
#   INFRA__DATABASE__TIMESCALE_URL → settings.infra.database.timescale_url
#
# Values shown here match config.yaml defaults. Override only
# what differs per environment.
# ═══════════════════════════════════════════════════════════


# ── Common ──────────────────────────────────────────────────
COMMON__TIMEZONE=America/New_York

# Watchlist — JSON arrays (override config.yaml lists)
# NOTE: single-quote the value so bash source preserves inner double-quotes.
COMMON__WATCHLIST__FOR_TRADE='["AAPL","MSFT","NVDA","TSLA","AMZN","META","GOOGL","AMD","SPY","QQQ"]'
COMMON__WATCHLIST__FOR_TRADE_BENCHMARK='["SPY","QQQ"]'
COMMON__WATCHLIST__FOR_SIGNAL_BENCHMARK='["SPY","QQQ","IWM","TLT","^VIX"]'

# Logging
COMMON__LOGGING__LEVEL=INFO
COMMON__LOGGING__FORMAT=json

# Celery runtime
COMMON__CELERY__PREFETCH_MULTIPLIER=1
COMMON__CELERY__MAX_MEMORY_PER_CHILD=500000
COMMON__CELERY__TASK_ACKS_LATE=true
COMMON__CELERY__TASK_TRACK_STARTED=true
COMMON__CELERY__CONCURRENCY=0

# Beat
COMMON__BEAT__REDBEAT_LOCK_TIMEOUT=300

# Flower
COMMON__FLOWER__PORT=5555
COMMON__FLOWER__BASIC_AUTH_USER=admin
COMMON__FLOWER__BASIC_AUTH_PASSWORD=changeme


# ── Infrastructure ──────────────────────────────────────────
INFRA__DATABASE__TIMESCALE_URL=postgresql+asyncpg://trader:trader_dev@localhost:5432/algo_trader
INFRA__DATABASE__POSTGRES_URL=postgresql+asyncpg://trader:trader_dev@localhost:5433/algo_trader_biz
INFRA__REDIS__URL=redis://localhost:6379/0
INFRA__RABBITMQ__URL=amqp://trader:trader_dev@localhost:5672//
INFRA__MINIO__ENDPOINT=localhost:9000
INFRA__MINIO__ACCESS_KEY=minioadmin
INFRA__MINIO__SECRET_KEY=minioadmin
INFRA__MINIO__SECURE=false
INFRA__PROMETHEUS__URL=http://localhost:9090
INFRA__GRAFANA__URL=http://localhost:3300


# ── Data Service ────────────────────────────────────────────
# DATA_SERVICE__PROVIDERS__STOCK=yfinance
# DATA_SERVICE__PROVIDERS__OPTIONS=yfinance
# DATA_SERVICE__RESILIENCE__MAX_RETRIES=3
# DATA_SERVICE__RESILIENCE__CONCURRENT_SYMBOLS=3
DATA_SERVICE__WORKER__SCHEDULE__OPTIONS_CAPTURE_EVERY_MINUTES=5
DATA_SERVICE__WORKER__SCHEDULE__POST_MARKET_PIPELINE_TIME=18:30
DATA_SERVICE__WORKER__PIPELINE__CHUNK_SIZE=5
DATA_SERVICE__WORKER__PIPELINE__STOP_AFTER=compute_daily_signals


# ── Signal Service ──────────────────────────────────────────
# SIGNAL_SERVICE__IV_LOOKBACK_DAYS=252


# ── Analysis Service — LLM ──────────────────────────────────
ANALYSIS_SERVICE__LLM__PROVIDER=copilot
ANALYSIS_SERVICE__LLM__OPENAI__API_KEY=
ANALYSIS_SERVICE__LLM__OPENAI__MODEL=claude-opus-4.6
ANALYSIS_SERVICE__LLM__COPILOT__GITHUB_TOKEN=
ANALYSIS_SERVICE__LLM__COPILOT__CLI_PATH=copilot
ANALYSIS_SERVICE__LLM__COPILOT__MODEL=claude-opus-4.6
ANALYSIS_SERVICE__LLM__COPILOT__REASONING_EFFORT=medium
# ANALYSIS_SERVICE__LLM__ORCHESTRATOR_CHUNK_SIZE=5
# ANALYSIS_SERVICE__LLM__ORCHESTRATOR_MAX_PARALLEL=2
# ANALYSIS_SERVICE__LLM__MAX_CRITIC_REVISIONS=2


# ── Trade Service ───────────────────────────────────────────
TRADE_SERVICE__EXECUTION_INTERVAL=300
TRADE_SERVICE__TRADE_START_TIME=09:20
TRADE_SERVICE__BROKER__TYPE=paper
TRADE_SERVICE__BROKER__PAPER__INITIAL_CASH=100000.0
# TRADE_SERVICE__BROKER__FUTU__HOST=127.0.0.1
# TRADE_SERVICE__BROKER__FUTU__PORT=11111
# TRADE_SERVICE__BROKER__FUTU__TRADER_ID=
# TRADE_SERVICE__BROKER__FUTU__TRD_ENV=SIMULATE
# TRADE_SERVICE__BROKER__FUTU__MARKET=US
TRADE_SERVICE__RISK__STOP_LOSS__ENABLED=true
TRADE_SERVICE__RISK__STOP_LOSS__PORTFOLIO_LOSS_LIMIT=2000.0
TRADE_SERVICE__RISK__STOP_LOSS__POSITION_LOSS_LIMIT=500.0


# ── Docker Compose helpers (not Pydantic — used in compose YAML) ──
FLOWER_USER=admin
FLOWER_PASSWORD=changeme
RABBITMQ_USER=trader
RABBITMQ_PASS=trader_dev

